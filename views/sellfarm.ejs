<!-- ===== بوابة اختيار الموقع (تظهر عند الدخول) ===== -->
<div id="location-gate" aria-hidden="true">
  <div class="gate-backdrop" data-close="1"></div>
  <div class="gate-card" role="dialog" aria-modal="true" aria-labelledby="gate-title">
    <button class="gate-close" type="button" aria-label="إغلاق" data-close="1">×</button>
    <h3 id="gate-title">أين تريد البحث؟</h3>
    <p class="gate-note">اختر المحافظة وأدخل المنطقة (اختياريًا) لنظهر لك نتائج أدقّ.</p>

    <div class="gate-fields">
      <label class="gate-label" for="gate-city">المحافظة</label>
      <select id="gate-city" class="gate-input">
        <option value="">اختر المحافظة…</option>
        <option>دمشق</option>
        <option>ريف دمشق</option>
        <option>حلب</option>
        <option>حمص</option>
        <option>حماة</option>
        <option>اللاذقية</option>
        <option>طرطوس</option>
        <option>إدلب</option>
        <option>دير الزور</option>
        <option>الحسكة</option>
        <option>الرقة</option>
        <option>درعا</option>
        <option>القنيطرة</option>
        <option>السويداء</option>
      </select>

      <label class="gate-label" for="gate-area">المنطقة (اختياري)</label>
      <input id="gate-area" class="gate-input" type="text" placeholder="مثال: قدسيا، المزة،...">
    </div>

    <div class="gate-actions">
      <button id="gate-apply" class="gate-btn gate-primary" type="button">اعرض النتائج</button>
      <button class="gate-btn" type="button" data-close="1">تخطّي الآن</button>
    </div>
  </div>
</div>

<!-- الفلاتر -->
<section id="filters" class="section filters" aria-labelledby="filters-title">
  <div class="container">
    <details class="filter-dropdown" open>
      <summary id="filters-title">تصفية النتائج</summary>

      <form id="sale-filters" class="filters-form" action="#results" method="get" novalidate>
        <div class="filters-grid">
          <!-- الأساسي (يظهر دائمًا) -->
         <div class="field">
  <label class="label" for="city">المحافظة</label>
  <select id="city" name="city" class="input">
    <option value="">اختر المحافظة…</option>
    <option>دمشق</option>
    <option>ريف دمشق</option>
    <option>حلب</option>
    <option>حمص</option>
    <option>حماة</option>
    <option>اللاذقية</option>
    <option>طرطوس</option>
    <option>إدلب</option>
    <option>دير الزور</option>
    <option>الحسكة</option>
    <option>الرقة</option>
    <option>درعا</option>
    <option>القنيطرة</option>
    <option>السويداء</option>
  </select>
</div>

          <div class="field">
            <label class="label" for="area">المنطقة</label>
            <input id="area" name="area" type="text" placeholder="اكتب اسم المنطقة (مثال: ريف دمشق)" />
          </div>

          <!-- زر المزيد/أقل -->
          <div class="field field--actions">
            <button id="toggle-advanced" class="btn btn-outline" type="button" aria-expanded="false" aria-controls="advanced-fields">
              المزيد
            </button>
            <button class="btn btn-primary" type="submit" style="margin-inline-start:.5rem">تطبيق</button>
          </div>
        </div>

        <!-- الحقول المتقدمة (مخفية افتراضيًا) -->
        <div id="advanced-fields" class="filters-grid advanced-fields" hidden>
          <div class="field">
            <label class="label" for="price-min">السعر (من)</label>
            <input id="price-min" name="price_min" type="number" placeholder="مثال: 50000" />
          </div>

          <div class="field">
            <label class="label" for="price-max">السعر (إلى)</label>
            <input id="price-max" name="price_max" type="number" placeholder="مثال: 500000" />
          </div>

          <div class="field">
            <label class="label" for="size-min">المساحة (من م²)</label>
            <input id="size-min" name="size_min" type="number" placeholder="مثال: 5000" />
          </div>

          <div class="field">
            <label class="label" for="size-max">المساحة (إلى م²)</label>
            <input id="size-max" name="size_max" type="number" placeholder="مثال: 25000" />
          </div>
        </div>
      </form>
    </details>
  </div>
</section>
<!-- VIP Sale Only -->
<section id="vip-sale" class="vip-sale-section" aria-labelledby="vip-sale-title" hidden>
  <div class="container">
    <header class="section-header">
      <h2 id="vip-sale-title">مزارع للبيع</h2>
      <p class="muted">اضغط على البطاقة لفتح صفحة تفاصيل المزرعة.</p>
    </header>

    <div class="swiper vip-swiper" dir="rtl">
